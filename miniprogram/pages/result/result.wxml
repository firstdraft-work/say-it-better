<view class="page" wx:if="{{isLoading}}">
  <view class="card loading-state">
    <view class="skeleton skeleton-title"></view>
    <view class="skeleton skeleton-text skeleton-text-long"></view>
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-short"></view>
  </view>
  <view class="card">
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-long mt-md"></view>
    <view class="skeleton skeleton-text skeleton-text-short mt-lg"></view>
  </view>
</view>

<view class="page" wx:elif="{{result}}">
  <view class="card">
    <view class="flex-between">
      <view class="text-title">识别结果</view>
      <button size="mini" bindtap="onFavorite">{{isFavorite ? '已收藏' : '收藏'}}</button>
    </view>
    <view class="text-meta mt-md">
      场景：{{result.analysis.scene}} · 关系：{{result.analysis.relation}} · 目标：{{result.analysis.goal}}
    </view>
    <view class="text-meta mt-sm">
      语气标签：{{result.analysis.toneTagsText}} · 情绪强度：{{result.analysis.emotionLevel}}/5
    </view>
    <view class="text-meta mt-sm" wx:if="{{result.analysis.riskPointsText}}">
      风险点：{{result.analysis.riskPointsText}}
    </view>
  </view>

  <view class="card variant-{{item.type}}" wx:for="{{result.variants}}" wx:key="type">
    <view class="text-subtitle">{{item.title}}</view>
    <view class="text-body mt-md">{{item.text}}</view>
    <view class="flex-row mt-lg">
      <button size="mini" data-text="{{item.text}}" data-type="{{item.type}}" bindtap="onCopy">复制</button>
      <button size="mini" data-text="{{item.text}}" data-type="{{item.type}}" bindtap="onPlay">
        {{playingVariantType === item.type ? '停止播放' : (ttsLoadingVariantType === item.type ? '生成中...' : '转语音')}}
      </button>
    </view>
  </view>
</view>
