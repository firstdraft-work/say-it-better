<view class="page" wx:if="{{isLoading}}">
  <view class="card loading-state">
    <view class="skeleton skeleton-title"></view>
    <view class="skeleton skeleton-text skeleton-text-long"></view>
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-short"></view>
  </view>
  <view class="card">
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-long mt-md"></view>
    <view class="skeleton skeleton-text skeleton-text-short mt-lg"></view>
  </view>
</view>

<view class="page" wx:elif="{{result}}">
  <view class="card">
    <view class="flex-between">
      <view class="result-title">分析结果</view>
      <view class="fav-btn {{isFavorite ? 'fav-btn-active' : ''}}" bindtap="onFavorite">
        <view class="fav-icon"></view>
        <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
    </view>

    <view class="chip-row">
      <view class="chip">
        <view class="chip-dot chip-dot-scene"></view>
        <text>{{result.analysis.scene}}</text>
      </view>
      <view class="chip">
        <view class="chip-dot chip-dot-relation"></view>
        <text>{{result.analysis.relation}}</text>
      </view>
      <view class="chip">
        <view class="chip-dot chip-dot-goal"></view>
        <text>{{result.analysis.goal}}</text>
      </view>
    </view>

    <view class="tone-row" wx:if="{{result.analysis.toneTagsText}}">
      <text class="tone-label">语气</text>
      <text class="tone-text">{{result.analysis.toneTagsText}}</text>
    </view>

    <view class="emotion-row">
      <text class="emotion-label">情绪强度</text>
      <view class="emotion-dots">
        <view wx:for="{{5}}" wx:key="*this" class="emotion-dot {{item < result.analysis.emotionLevel ? 'emotion-dot-filled' : ''}}"></view>
      </view>
    </view>

    <view class="risk-row" wx:if="{{result.analysis.riskPointsText}}">
      <view class="risk-icon"></view>
      <text class="risk-text">{{result.analysis.riskPointsText}}</text>
    </view>
  </view>

  <view class="card variant-card variant-{{item.type}}" wx:for="{{result.variants}}" wx:key="type">
    <view class="variant-title">{{item.title}}</view>
    <view class="variant-text">{{item.text}}</view>
    <view class="variant-actions">
      <button size="mini" class="action-btn" data-text="{{item.text}}" data-type="{{item.type}}" bindtap="onCopy">复制</button>
      <button size="mini" class="action-btn" data-text="{{item.text}}" data-type="{{item.type}}" bindtap="onPlay">
        {{playingVariantType === item.type ? '停止' : (ttsLoadingVariantType === item.type ? '生成中...' : '播放')}}
      </button>
    </view>
  </view>
</view>
