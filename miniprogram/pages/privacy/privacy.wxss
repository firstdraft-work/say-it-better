.page {
  padding: 32rpx;
  background-color: #F6EFE7;
  min-height: 100vh;
}

.section {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.update-date {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.subtitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.paragraph {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
