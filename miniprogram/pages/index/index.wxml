<view class="page">
  <view class="card">
    <view style="font-size: 44rpx; font-weight: 700;">Say It Better 沟通助手</view>
    <view style="margin-top: 16rpx; color: #7d6a5c;">把难开口的话，说得更得体。输入原话，我们给你三种更合适的表达方式。</view>
    <view style="margin-top: 12rpx; color: #9a8575; font-size: 24rpx;">当前联调地址：{{apiBaseUrl}}</view>

    <textarea
      style="width: 100%; height: 260rpx; margin-top: 24rpx; background: #fff; border-radius: 24rpx; padding: 20rpx; box-sizing: border-box;"
      placeholder="例如：你这周到底能不能把方案给我？别再拖了。"
      value="{{inputText}}"
      bindinput="onInputChange"
    />

    <view style="margin-top: 24rpx;">
      <view class="tag {{selectedScene === 'workplace' ? 'scene-active' : ''}}" data-scene="workplace" bindtap="onSelectScene">职场沟通</view>
      <view class="tag {{selectedScene === 'family' ? 'scene-active' : ''}}" data-scene="family" bindtap="onSelectScene">家庭关系</view>
      <view class="tag {{selectedScene === 'social' ? 'scene-active' : ''}}" data-scene="social" bindtap="onSelectScene">社交关系</view>
    </view>

    <view style="margin-top: 22rpx;">
      <view style="font-size: 26rpx; color: #7d6a5c; margin-bottom: 12rpx;">关系选择（可选）</view>
      <view wx:for="{{relationOptions}}" wx:key="value" class="tag {{selectedRelation === item.value ? 'scene-active' : ''}}" data-relation="{{item.value}}" bindtap="onSelectRelation">
        {{item.label}}
      </view>
    </view>

    <view style="margin-top: 22rpx;">
      <view style="font-size: 26rpx; color: #7d6a5c; margin-bottom: 12rpx;">沟通目标（可选）</view>
      <view wx:for="{{goalOptions}}" wx:key="value" class="tag {{selectedGoal === item.value ? 'scene-active' : ''}}" data-goal="{{item.value}}" bindtap="onSelectGoal">
        {{item.label}}
      </view>
    </view>

    <view style="margin-top: 24rpx;">
      <voice-recorder
        disabled="{{isTranscribing || isSubmitting}}"
        bind:recordingchange="onRecordingChange"
        bind:recorded="onRecorded"
        bind:recorderror="onRecordError"
      />
      <view style="margin-top: 14rpx; color: #7d6a5c;">
        {{isTranscribing ? '正在转写语音...' : voiceTips}}
      </view>
    </view>

    <view style="margin-top: 20rpx; font-size: 24rpx; color: #9a8575; line-height: 1.7;">
      录音内容仅用于语音转文字与表达优化；文本优化由云端大模型完成，语音识别与语音合成由腾讯云提供支持。
    </view>

    <button class="btn-primary" style="margin-top: 28rpx;" loading="{{isSubmitting}}" bindtap="onSubmit">
      开始优化表达
    </button>
  </view>
</view>
