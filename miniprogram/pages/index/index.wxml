<view class="page">
  <view class="header-title">Say It Better</view>
  <view class="header-subtitle">把难开口的话，说得更得体。</view>

  <view class="card" style="margin-top: 28rpx;">
    <textarea
      class="input-area"
      placeholder="输入你想优化的话，例如：你这周到底能不能把方案给我？"
      value="{{inputText}}"
      bindinput="onInputChange"
      maxlength="500"
    />
    <view class="char-count">{{charCount}}/500</view>

    <view class="scene-row">
      <view class="tag {{selectedScene === 'workplace' ? 'scene-active' : ''}}" data-scene="workplace" bindtap="onSelectScene">职场沟通</view>
      <view class="tag {{selectedScene === 'family' ? 'scene-active' : ''}}" data-scene="family" bindtap="onSelectScene">家庭关系</view>
      <view class="tag {{selectedScene === 'social' ? 'scene-active' : ''}}" data-scene="social" bindtap="onSelectScene">社交关系</view>
    </view>

    <view class="advanced-toggle" bindtap="toggleAdvanced">
      <text>更多选项</text>
      <text style="margin-left: 8rpx;">{{showAdvanced ? '▴' : '▾'}}</text>
    </view>

    <view wx:if="{{showAdvanced}}">
      <view class="section-label">关系选择</view>
      <view class="tag-row">
        <view wx:for="{{relationOptions}}" wx:key="value" class="tag {{selectedRelation === item.value ? 'scene-active' : ''}}" data-relation="{{item.value}}" bindtap="onSelectRelation">
          {{item.label}}
        </view>
      </view>

      <view class="section-label" style="margin-top: 16rpx;">沟通目标</view>
      <view class="tag-row">
        <view wx:for="{{goalOptions}}" wx:key="value" class="tag {{selectedGoal === item.value ? 'scene-active' : ''}}" data-goal="{{item.value}}" bindtap="onSelectGoal">
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <view class="card" style="margin-top: 20rpx;">
    <voice-recorder
      disabled="{{isTranscribing || isSubmitting}}"
      bind:recordingchange="onRecordingChange"
      bind:recorded="onRecorded"
      bind:recorderror="onRecordError"
    />
    <view class="voice-tip">
      {{isTranscribing ? '正在转写语音...' : voiceTips}}
    </view>

    <button class="btn-primary" style="margin-top: 24rpx;" loading="{{isSubmitting}}" bindtap="onSubmit">
      开始优化表达
    </button>
  </view>

  <view class="footer-notice">
    录音仅用于语音转文字与表达优化，文本由云端大模型处理
  </view>
</view>
