/* Header */
.header {
  padding: 8rpx 4rpx 0;
}

.header-brand {
  font-size: 48rpx;
  font-weight: 800;
  color: #2f241f;
  letter-spacing: -0.5rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #7d6a5c;
  margin-top: 8rpx;
}

/* Card labels */
.card-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #5a4638;
  margin-bottom: 16rpx;
}

/* Input */
.input-area {
  width: 100%;
  height: 220rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #2f241f;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #9a8575;
  margin-top: 8rpx;
}

/* Scene tags — wider, with icon */
.scene-row {
  display: flex;
  gap: 12rpx;
}

.scene-tag {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: #efe2d2;
  color: #7b5741;
  font-size: 26rpx;
  font-weight: 500;
  transition: transform 0.1s ease, background 0.2s ease;
  box-sizing: border-box;
}

.scene-tag:active {
  transform: scale(0.97);
}

.scene-tag.scene-active {
  background: #b85c38;
  color: #fff;
}

.scene-tag.scene-active .scene-icon {
  border-color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.25);
}

/* Scene icons — CSS shapes */
.scene-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
  box-sizing: border-box;
}

.scene-icon-work {
  border: none;
  border-radius: 4rpx;
  background: currentColor;
  position: relative;
}

.scene-icon-work::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.scene-icon-family {
  border: none;
  background: transparent;
  position: relative;
}

.scene-icon-family::before {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 3rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
}

.scene-icon-family::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 1rpx;
  width: 18rpx;
  height: 10rpx;
  border-radius: 10rpx 10rpx 0 0;
  border: 3rpx solid currentColor;
  border-bottom: none;
}

.scene-icon-social {
  border: none;
  background: transparent;
  position: relative;
}

.scene-icon-social::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 2.5rpx solid currentColor;
}

.scene-icon-social::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 2.5rpx solid currentColor;
}

/* Section labels */
.section-label {
  font-size: 24rpx;
  color: #7d6a5c;
  margin-bottom: 12rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* Advanced toggle */
.advanced-toggle {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #b85c38;
  font-weight: 500;
}

.toggle-arrow {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #b85c38;
  margin-left: 8rpx;
  transition: transform 0.2s ease;
}

.toggle-arrow-up {
  transform: rotate(180deg);
}

/* Advanced panel — animated collapse */
.advanced-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.advanced-panel-open {
  max-height: 600rpx;
}

/* Action card */
.action-card {
  background: rgba(255, 252, 247, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(96, 64, 40, 0.08);
  padding: 28rpx;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

.voice-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d6a5c;
}

/* Submit button */
.btn-submit {
  margin-top: 24rpx;
  width: 100%;
  font-size: 32rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(184, 92, 56, 0.25);
}

.btn-submit[disabled] {
  opacity: 0.6;
  box-shadow: none;
}

/* Footer */
.footer-notice {
  text-align: center;
  font-size: 22rpx;
  color: #b5a69a;
  margin-top: 24rpx;
  padding-bottom: 32rpx;
}

/* Override global scene-active when used in scene-tag context */
.scene-tag.scene-active {
  background: #b85c38;
  color: #fff;
}
