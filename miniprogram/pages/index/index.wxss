.scene-active {
  background: #b85c38;
  color: #fff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2f241f;
  padding-left: 4rpx;
}

.header-subtitle {
  font-size: 30rpx;
  color: #7d6a5c;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.input-area {
  width: 100%;
  height: 240rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #9a8575;
  margin-top: 8rpx;
}

.scene-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: #7d6a5c;
  margin-bottom: 12rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.advanced-toggle {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #b85c38;
}

.voice-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d6a5c;
}

.footer-notice {
  text-align: center;
  font-size: 22rpx;
  color: #b5a69a;
  margin-top: 24rpx;
  padding-bottom: 32rpx;
}
