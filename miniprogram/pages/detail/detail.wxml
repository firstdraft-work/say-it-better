<view class="page">
  <view wx:if="{{isLoading}}" class="card loading-state">
    <view class="skeleton skeleton-title"></view>
    <view class="skeleton skeleton-text skeleton-text-long"></view>
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-short"></view>
  </view>

  <view wx:elif="{{detail}}">
    <view class="card">
      <view class="detail-title">原始输入</view>
      <view class="detail-text">{{detail.originalText}}</view>

      <view class="chip-row">
        <view class="chip">
          <view class="chip-dot chip-dot-scene"></view>
          <text>{{detail.analysis.scene}}</text>
        </view>
        <view class="chip">
          <view class="chip-dot chip-dot-relation"></view>
          <text>{{detail.analysis.relation}}</text>
        </view>
        <view class="chip">
          <view class="chip-dot chip-dot-goal"></view>
          <text>{{detail.analysis.goal}}</text>
        </view>
      </view>

      <view class="tone-row" wx:if="{{detail.analysis.toneTagsText}}">
        <text class="tone-label">语气</text>
        <text class="tone-text">{{detail.analysis.toneTagsText}}</text>
      </view>

      <view class="emotion-row">
        <text class="emotion-label">情绪强度</text>
        <view class="emotion-dots">
          <view wx:for="{{5}}" wx:key="*this" class="emotion-dot {{item < detail.analysis.emotionLevel ? 'emotion-dot-filled' : ''}}"></view>
        </view>
      </view>

      <view class="risk-row" wx:if="{{detail.analysis.riskPointsText}}">
        <view class="risk-icon"></view>
        <text class="risk-text">{{detail.analysis.riskPointsText}}</text>
      </view>
    </view>

    <view class="card variant-card variant-{{item.type}}" wx:for="{{detail.variants}}" wx:key="type">
      <view class="variant-title">{{item.title}}</view>
      <view class="variant-text">{{item.text}}</view>
    </view>

    <view class="delete-area">
      <button class="btn-destructive" bindtap="onDelete">删除这条记录</button>
    </view>
  </view>
</view>
