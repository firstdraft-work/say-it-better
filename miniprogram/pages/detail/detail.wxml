<view class="page">
  <view wx:if="{{isLoading}}" class="card loading-state">
    <view class="skeleton skeleton-title"></view>
    <view class="skeleton skeleton-text skeleton-text-long"></view>
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-short"></view>
  </view>

  <view wx:elif="{{detail}}">
    <view class="card">
      <view class="text-title">原始输入</view>
      <view class="text-body mt-md">{{detail.originalText}}</view>
      <view class="text-meta mt-md">
        场景：{{detail.analysis.scene}} · 关系：{{detail.analysis.relation}} · 目标：{{detail.analysis.goal}}
      </view>
      <view class="text-meta mt-sm">
        语气标签：{{detail.analysis.toneTagsText}} · 情绪强度：{{detail.analysis.emotionLevel}}/5
      </view>
      <view class="text-meta mt-sm" wx:if="{{detail.analysis.riskPointsText}}">
        风险点：{{detail.analysis.riskPointsText}}
      </view>
    </view>

    <view class="card variant-{{item.type}}" wx:for="{{detail.variants}}" wx:key="type">
      <view class="text-section">{{item.title}}</view>
      <view class="text-body mt-md">{{item.text}}</view>
    </view>

    <button class="btn-destructive mt-lg" bindtap="onDelete">删除这条记录</button>
  </view>
</view>
