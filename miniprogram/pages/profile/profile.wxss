/* Profile header */
.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c47a52, #b85c38);
  flex-shrink: 0;
  position: relative;
}

.avatar::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f241f;
}

.profile-id {
  font-size: 24rpx;
  color: #9a8575;
  margin-top: 4rpx;
}

/* Stats row */
.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 252, 247, 0.92);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(96, 64, 40, 0.06);
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #b85c38;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #9a8575;
  margin-top: 8rpx;
}

/* Card sections */
.card-section {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
  margin-bottom: 12rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.setting-value {
  font-size: 28rpx;
  color: #3d2e25;
}

.setting-hint {
  font-size: 22rpx;
  color: #9a8575;
  background: #f5ece3;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* Info text */
.info-text {
  font-size: 26rpx;
  color: #5a4638;
  line-height: 1.7;
  margin-top: 12rpx;
}

/* Link card */
.link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #b85c38;
}

.link-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #b85c38;
  border-bottom: 3rpx solid #b85c38;
  transform: rotate(-45deg);
}
