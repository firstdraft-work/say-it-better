<view class="page">
  <view class="card" wx:if="{{isLoading}}">
    <view class="skeleton skeleton-title"></view>
    <view class="skeleton skeleton-text skeleton-text-long"></view>
    <view class="skeleton skeleton-text skeleton-text-medium"></view>
    <view class="skeleton skeleton-text skeleton-text-long mt-md"></view>
    <view class="skeleton skeleton-text skeleton-text-short mt-lg"></view>
  </view>

  <block wx:else>
    <view class="card search-card">
      <input
        class="search-input"
        placeholder="搜索原话、场景或关系"
        value="{{searchKeyword}}"
        bindinput="onSearchChange"
      />
      <view class="filter-row mt-md">
        <view class="filter-tag {{activeFilter === 'all' ? 'filter-active' : ''}}" data-filter="all" bindtap="onFilterChange">全部</view>
        <view class="filter-tag {{activeFilter === 'favorites' ? 'filter-active' : ''}}" data-filter="favorites" bindtap="onFilterChange">仅收藏</view>
      </view>
    </view>

    <block wx:for="{{groupedList}}" wx:key="date">
      <view class="date-header">
        <view class="date-line"></view>
        <text class="date-text">{{item.date}}</text>
        <view class="date-line"></view>
      </view>

      <view class="card history-card" wx:for="{{item.records}}" wx:key="recordId" wx:for-item="record">
        <view class="history-body" data-id="{{record.recordId}}" bindtap="onOpenDetail">
          <view class="history-text">{{record.originalText}}</view>
          <view class="history-meta">
            <view class="scene-badge scene-badge-{{record.scene}}">{{record.sceneLabel}}</view>
            <text class="meta-sep">·</text>
            <text class="meta-relation">{{record.relation}}</text>
          </view>
        </view>
        <view class="history-actions">
          <view class="fav-toggle {{record.favorite ? 'fav-toggle-active' : ''}}" data-id="{{record.recordId}}" data-favorite="{{record.favorite}}" bindtap="onToggleFavorite">
          </view>
        </view>
      </view>
    </block>

    <view class="card empty-state" wx:if="{{!groupedList.length}}">
      <view class="empty-illustration">
        <view class="empty-line"></view>
        <view class="empty-line empty-line-short"></view>
        <view class="empty-line empty-line-medium"></view>
      </view>
      <view class="empty-text">还没有符合条件的记录</view>
      <view class="text-hint mt-sm">先去首页生成一条试试吧</view>
    </view>

    <view wx:if="{{isLoadingMore}}" class="loading-more">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>
  </block>
</view>
