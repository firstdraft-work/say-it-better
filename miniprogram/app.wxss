page {
  background: linear-gradient(180deg, #f8f1e8 0%, #f3ebe2 100%);
  color: #2f241f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.page {
  padding: 24rpx;
}

/* Card system */
.card {
  background: rgba(255, 252, 247, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(96, 64, 40, 0.08);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* Typography */
.text-title {
  font-size: 36rpx;
  font-weight: 700;
}

.text-subtitle {
  font-size: 32rpx;
  font-weight: 700;
}

.text-section {
  font-size: 30rpx;
  font-weight: 700;
}

.text-body {
  line-height: 1.8;
}

.text-meta {
  color: #7d6a5c;
  font-size: 26rpx;
}

.text-hint {
  color: #9a8575;
  font-size: 24rpx;
}

.text-accent {
  color: #b85c38;
}

/* Spacing helpers */
.mt-xs { margin-top: 8rpx; }
.mt-sm { margin-top: 12rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mt-xl { margin-top: 32rpx; }

/* Flex helpers */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-row {
  display: flex;
  gap: 20rpx;
}

/* Button system */
.btn-primary {
  background: #b85c38;
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 32rpx;
  font-weight: 600;
  border: none;
  transition: transform 0.1s ease;
}

.btn-primary:active {
  transform: scale(0.96);
}

.btn-destructive {
  background: #d94a38;
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 32rpx;
  font-weight: 600;
  border: none;
  transition: transform 0.1s ease;
}

.btn-destructive:active {
  transform: scale(0.96);
}

.btn-link {
  background: transparent;
  color: #b85c38;
  border: none;
  font-size: 30rpx;
  padding: 0;
  transition: opacity 0.1s ease;
}

.btn-link:active {
  opacity: 0.7;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: #efe2d2;
  color: #7b5741;
  font-size: 26rpx;
  transition: transform 0.1s ease;
  min-height: 60rpx;
  box-sizing: border-box;
}

.tag:active {
  transform: scale(0.95);
}

.scene-active {
  background: #b85c38;
  color: #fff;
}

/* Variant type colors */
.variant-polite { border-left: 6rpx solid #8fb369; }
.variant-direct { border-left: 6rpx solid #b85c38; }
.variant-professional { border-left: 6rpx solid #6b8fb3; }
.variant-empathetic { border-left: 6rpx solid #c49b5a; }

/* Loading state */
.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: #7d6a5c;
}

/* Skeleton loading */
.skeleton {
  background: linear-gradient(90deg, #f0e6da 25%, #f8f1e8 50%, #f0e6da 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

.skeleton-title {
  height: 36rpx;
  width: 50%;
  margin-bottom: 24rpx;
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 12rpx;
}

.skeleton-text-long { width: 100%; }
.skeleton-text-medium { width: 70%; }
.skeleton-text-short { width: 40%; }

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #d4c8bc;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7d6a5c;
  line-height: 1.6;
}

/* Mini button override */
button[size="mini"] {
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  transition: transform 0.1s ease;
}

button[size="mini"]:active {
  transform: scale(0.95);
}
