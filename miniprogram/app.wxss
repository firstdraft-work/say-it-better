page {
  background: linear-gradient(180deg, #f8f1e8 0%, #f3ebe2 100%);
  color: #2f241f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: rgba(255, 252, 247, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(96, 64, 40, 0.08);
  padding: 28rpx;
}

.btn-primary {
  background: #b85c38;
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 32rpx;
  font-weight: 600;
}

.tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  background: #efe2d2;
  color: #7b5741;
}
